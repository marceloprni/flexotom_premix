<%- include ('../partials/header.ejs'); -%>
<%- include ('../partials/navbar.ejs'); -%>

<main class="container_main_materia">
    <section class="container_section_first_materia">
        <div class="group_seleciona_materia_materia">
            <div class="form-group group_input_parametros_materia">
              <label for="">MATERIA PRIMA</label>
              <select class="form-control selectPrima_materia" id="materiaPrima"></select>
            </div>

            <div class="form-group group_input_parametros_materia">
                <label for="">LOTE</label>
                <input type="text" class="form-control inputPrima_materia" id="materiaPrimaLote" placeholder="">
            </div>

            <button class="btn_criar_materia" id="btnCriarLote">CRIAR LOTE</button>
        </div>

        <div class="group_selectiona_btn_materia">
            <button class="btn_tabela_materia" id="btn_imprimir">IMPRIMIR LOTE</button>
            <button class="btn_tabela_materia" id="btn_deletar">DELETAR LOTE</button>
        </div>
    </section>
    
    <section class="container_section_second">
        <div class="container_table_materia">
            <table class="table text-black tabela_Cadastro" id="tabela-CadastroLote_materia"></table>
        </div>
    </section>
</main>

<div class="modal fade justify-content-center align-items-center align-self-center" id="barCodeModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" id="messageDiv" role="document">
        <div class="modal-content" id="barCodeDiv_materia">
            <div class="modal-body justify-content-center align-items-center align-self-center text-center" id="barCodeBody">
                <p id="mensagemBarcode"></p>
                <img id="idBarcode"></img>
                <button type="button" class="btn btn-dark" id="btn_imprimir_barcode">IMPRIMIR</button>
            </div>
        </div>
    </div>
</div>

<%- include ('../partials/footer.ejs'); -%>
<script type="module" src="/js/cadastroLoteMateria/cadastroLoteMateria.js"></script>